<div class="layout">
  <div class="flex flex--col py--3 px--4" style="width:100%;height:100%;box-sizing:border-box;overflow:hidden;">

    <div class="flex mb--2" style="align-items:baseline;gap:10px;flex-shrink:0;">
      <span style="font-size:17px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">{{ merge_variables.stop.libelle }}</span>
      <span style="font-size:12px;font-weight:400;opacity:0.55;white-space:nowrap;">{{ merge_variables.stop.distance }}</span>
    </div>

    <div class="bg--black mb--1.5" style="width:100%;height:1.5px;flex-shrink:0;"></div>

    <div class="flex flex--center-y pb--1" style="gap:8px;flex-shrink:0;">
      <span style="min-width:36px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Ligne</span>
      <span style="flex:1;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Direction</span>
      <span class="text--right" style="min-width:46px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Attente</span>
      <span style="width:8px;"></span>
    </div>

    {% for dep in merge_variables.departures %}
    {% if dep.ligne.typeLigne == 1 %}{% assign badge_class = "rounded--[4px]" %}{% else %}{% assign badge_class = "rounded--[11px]" %}{% endif %}
    {% if dep.tempsReel == "true" %}{% assign time_opacity = "1" %}{% assign dot_style = "background:#111;" %}{% else %}{% assign time_opacity = "0.45" %}{% assign dot_style = "border:1.5px solid rgba(0,0,0,0.25);" %}{% endif %}
    <div class="flex flex--center-y py--[5px]" style="gap:8px;border-bottom:1px solid rgba(0,0,0,0.12);flex-shrink:0;">
      <div class="flex flex--center-x flex--center-y bg--black text--white {{ badge_class }}" style="min-width:36px;height:22px;font-size:12px;font-weight:700;flex-shrink:0;">{{ dep.ligne.numLigne }}</div>
      <div style="flex:1;font-size:13px;font-weight:500;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">&#8594; {{ dep.terminus }}</div>
      <div class="text--right" style="min-width:46px;font-size:14px;font-weight:700;flex-shrink:0;opacity:{{ time_opacity }};">{{ dep.temps }}</div>
      <div class="rounded--full" style="width:6px;height:6px;flex-shrink:0;{{ dot_style }}"></div>
    </div>
    {% else %}
    <div class="py--3" style="font-size:13px;opacity:0.5;">Aucun d&eacute;part disponible</div>
    {% endfor %}

  </div>
</div>
<div class="title_bar">
  <span class="title">Naolib - Départs à proximité</span>
  <span class="instance">{{ merge_variables.refreshed_at }}</span>
</div>
</div>
