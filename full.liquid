<div class="layout">
  <div style="display:flex;flex-direction:column;width:100%;height:100%;padding:12px 16px;box-sizing:border-box;overflow:hidden;">

    <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:8px;flex-shrink:0;">
      <span style="font-size:17px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">{{ merge_variables.stop.libelle }}</span>
      <span style="font-size:12px;font-weight:400;opacity:0.55;white-space:nowrap;">{{ merge_variables.stop.distance }}</span>
    </div>

    <div style="width:100%;height:1.5px;background:#111;margin-bottom:6px;flex-shrink:0;"></div>

    <div style="display:flex;align-items:center;gap:8px;padding:0 0 4px 0;flex-shrink:0;">
      <span style="min-width:36px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Ligne</span>
      <span style="flex:1;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Direction</span>
      <span style="min-width:46px;text-align:right;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Attente</span>
      <span style="width:8px;"></span>
    </div>

    {% for dep in merge_variables.departures %}
    {% if dep.ligne.typeLigne == 1 %}{% assign badge_radius = "4px" %}{% else %}{% assign badge_radius = "11px" %}{% endif %}
    {% if dep.tempsReel == "true" %}{% assign time_opacity = "1" %}{% assign dot_style = "background:#111;" %}{% else %}{% assign time_opacity = "0.45" %}{% assign dot_style = "border:1.5px solid rgba(0,0,0,0.25);" %}{% endif %}
    <div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(0,0,0,0.12);flex-shrink:0;">
      <div style="min-width:36px;height:22px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;background:#111;color:#fff;flex-shrink:0;border-radius:{{ badge_radius }};">{{ dep.ligne.numLigne }}</div>
      <div style="flex:1;font-size:13px;font-weight:500;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">&#8594; {{ dep.terminus }}</div>
      <div style="min-width:46px;text-align:right;font-size:14px;font-weight:700;flex-shrink:0;opacity:{{ time_opacity }};">{{ dep.temps }}</div>
      <div style="width:6px;height:6px;border-radius:50%;flex-shrink:0;{{ dot_style }}"></div>
    </div>
    {% else %}
    <div style="font-size:13px;opacity:0.5;padding:12px 0;">Aucun d&eacute;part disponible</div>
    {% endfor %}

  </div>
</div>
<div class="title_bar">
  <span class="title">Naolib - Départs à proximité</span>
  <span class="instance">{{ merge_variables.refreshed_at }}</span>
</div>
</div>