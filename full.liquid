<div class="screen">
  <div class="view view--full">
    <div class="layout" style="padding:0;height:calc(100% - 32px);">
      <div id="naolib-board" style="display:flex;flex-direction:column;width:100%;height:100%;padding:12px 16px;box-sizing:border-box;overflow:hidden;"></div>
    </div>
    <div class="title_bar">
      <span class="title">Naolib</span>
      <span class="instance" id="updated-time"></span>
    </div>
  </div>
</div>

<script>
  // Preview data – in the TRMNL editor, replace STOPS_DATA with: {{ data | json }}
  const STOPS_DATA = [
    {"codeLieu":"CRQU","libelle":"Place du Cirque","distance":"63 m","ligne":[{"numLigne":"11"},{"numLigne":"2"},{"numLigne":"23"}]},
    {"codeLieu":"COMM","libelle":"Commerce","distance":"343 m","ligne":[{"numLigne":"1"},{"numLigne":"2"},{"numLigne":"C1"}]}
  ];

  const PREVIEW_DEPARTURES = [
    {"sens":1,"terminus":"Orvault Grand Val","infotrafic":false,"temps":"3mn","dernierDepart":"false","tempsReel":"true","ligne":{"numLigne":"11","typeLigne":3},"arret":{"codeArret":"CRQU1"}},
    {"sens":2,"terminus":"Pirmil","infotrafic":false,"temps":"8mn","dernierDepart":"false","tempsReel":"true","ligne":{"numLigne":"2","typeLigne":1},"arret":{"codeArret":"CRQU2"}},
    {"sens":1,"terminus":"Jamet","infotrafic":false,"temps":"5mn","dernierDepart":"false","tempsReel":"false","ligne":{"numLigne":"23","typeLigne":3},"arret":{"codeArret":"CRQU3"}},
    {"sens":2,"terminus":"Beaujoire","infotrafic":false,"temps":"12mn","dernierDepart":"false","tempsReel":"true","ligne":{"numLigne":"2","typeLigne":1},"arret":{"codeArret":"CRQU4"}},
    {"sens":1,"terminus":"Orvault Grand Val","infotrafic":false,"temps":"18mn","dernierDepart":"false","tempsReel":"false","ligne":{"numLigne":"11","typeLigne":3},"arret":{"codeArret":"CRQU5"}}
  ];

  async function fetchDepartures(stopCode) {
    try {
      const res = await fetch("https://open.tan.fr/ewp/tempsattente.json/" + stopCode);
      if (!res.ok) throw new Error("HTTP " + res.status);
      return await res.json();
    } catch (e) {
      return null;
    }
  }

  function renderBoard(stop, departures) {
    const board = document.getElementById("naolib-board");
    board.innerHTML = "";

    // Stop name header
    const header = document.createElement("div");
    header.style.cssText = "display:flex;align-items:baseline;gap:10px;margin-bottom:8px;flex-shrink:0;";

    const stopName = document.createElement("span");
    stopName.style.cssText = "font-size:17px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;";
    stopName.textContent = stop.libelle;

    const dist = document.createElement("span");
    dist.style.cssText = "font-size:12px;font-weight:400;opacity:0.55;white-space:nowrap;";
    dist.textContent = stop.distance;

    header.appendChild(stopName);
    header.appendChild(dist);
    board.appendChild(header);

    // Divider
    const hr = document.createElement("div");
    hr.style.cssText = "width:100%;height:1.5px;background:#111;margin-bottom:6px;flex-shrink:0;";
    board.appendChild(hr);

    // Column headers
    const colHeader = document.createElement("div");
    colHeader.style.cssText = "display:flex;align-items:center;gap:8px;padding:0 0 4px 0;flex-shrink:0;";
    colHeader.innerHTML = [
      '<span style="min-width:36px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Ligne</span>',
      '<span style="flex:1;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Direction</span>',
      '<span style="min-width:46px;text-align:right;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;opacity:0.45;">Attente</span>',
      '<span style="width:8px;"></span>',
    ].join("");
    board.appendChild(colHeader);

    // Filter departures that have a wait time
    const valid = (departures || []).filter(d => d.temps && d.temps.trim() !== "");

    if (valid.length === 0) {
      const empty = document.createElement("div");
      empty.style.cssText = "font-size:13px;opacity:0.5;padding:12px 0;";
      empty.textContent = "Aucun départ disponible";
      board.appendChild(empty);
    } else {
      for (const dep of valid.slice(0, 7)) {
        const isTram = dep.ligne.typeLigne === 1;
        const isRealtime = dep.tempsReel === "true";

        const row = document.createElement("div");
        row.style.cssText = "display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(0,0,0,0.12);flex-shrink:0;";

        // Line badge – rounded square for tram, pill for bus
        const badge = document.createElement("div");
        badge.style.cssText = [
          "min-width:36px",
          "height:22px",
          "display:flex",
          "align-items:center",
          "justify-content:center",
          "font-size:12px",
          "font-weight:700",
          "letter-spacing:0.02em",
          "background:#111",
          "color:#fff",
          "flex-shrink:0",
          isTram ? "border-radius:4px" : "border-radius:11px",
        ].join(";");
        badge.textContent = dep.ligne.numLigne;

        // Direction
        const direction = document.createElement("div");
        direction.style.cssText = "flex:1;font-size:13px;font-weight:500;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;";
        direction.textContent = "\u2192 " + dep.terminus;

        // Wait time
        const timeEl = document.createElement("div");
        timeEl.style.cssText = [
          "min-width:46px",
          "text-align:right",
          "font-size:14px",
          "font-weight:700",
          "flex-shrink:0",
          isRealtime ? "opacity:1;" : "opacity:0.45;",
        ].join(";");
        timeEl.textContent = dep.temps;

        // Real-time dot indicator
        const dot = document.createElement("div");
        dot.style.cssText = [
          "width:6px",
          "height:6px",
          "border-radius:50%",
          "flex-shrink:0",
          isRealtime ? "background:#111;" : "background:transparent;border:1.5px solid rgba(0,0,0,0.25);box-sizing:border-box;",
        ].join(";");

        row.appendChild(badge);
        row.appendChild(direction);
        row.appendChild(timeEl);
        row.appendChild(dot);
        board.appendChild(row);
      }
    }

    // Timestamp
    const now = new Date();
    const timeStr = now.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });
    const dateStr = now.toLocaleDateString("fr-FR", { day: "numeric", month: "short" });
    document.getElementById("updated-time").textContent = dateStr + ", " + timeStr;
  }

  function renderError(msg) {
    document.getElementById("naolib-board").innerHTML =
      '<div style="font-size:13px;opacity:0.5;padding:16px 0;">' + msg + "</div>";
  }

  async function init() {
    const stops = STOPS_DATA;
    if (!stops || !stops.length) {
      renderError("Aucun arrêt trouvé à ces coordonnées.");
      return;
    }

    const nearest = stops[0];
    const departures = await fetchDepartures(nearest.codeLieu);

    // Fall back to preview data only when running outside TRMNL (no real data)
    renderBoard(nearest, departures !== null ? departures : PREVIEW_DEPARTURES);
  }

  init();
</script>
